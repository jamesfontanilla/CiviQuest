# Copy to `.env` and fill in real values. Never commit `.env`.

# ── JWT ────────────────────────────────────────────────────────────────────
# MUST be a high-entropy random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Database ───────────────────────────────────────────────────────────────
# Local dev default (SQLite). In production, set this to your Supabase
# connection string (Session mode pooler, port 5432):
#   postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# IMPORTANT: Use the "Session mode" pooler URL from Supabase dashboard
# (Project Settings → Database → Connection pooling → Session mode).
# Do NOT use the direct connection URL in production — it bypasses the
# pooler and will exhaust connections on the free tier.
DATABASE_URL=sqlite:///data/cse.db

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Required for OTP and password-reset emails to reach real inboxes.
# 1. Sign up at https://resend.com (free: 3,000 emails/month, 100/day)
# 2. Add and verify your sending domain (or use the resend.dev sandbox for testing)
# 3. Create an API key and paste it here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address shown to recipients. Must match your verified Resend domain.
# Format: "Display Name <address@yourdomain.com>"
EMAIL_FROM_ADDR=CiviQuest <noreply@yourdomain.com>

# ── OTP (offline fallback) ─────────────────────────────────────────────────
# Path to the offline OTP log file. Only used when RESEND_API_KEY is unset
# (local dev without email credentials).
OTP_OFFLINE_LOG_PATH=data/otp_offline.log

# ── Google OAuth ───────────────────────────────────────────────────────────
# Required for "Continue with Google" authentication.
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application type)
# 3. Add http://localhost:8000 to Authorized JavaScript origins
# 4. Paste the Client ID here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
