# Copy to `.env` and fill in real values. Never commit `.env`.

# JWT signing secret. MUST be a high-entropy random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# SQLAlchemy database URL. Default is the local SQLite file used by uvicorn.
DATABASE_URL=sqlite:///data/cse.db

# Path to the offline OTP log file (used in offline mode per Req 2.8).
OTP_OFFLINE_LOG_PATH=data/otp_offline.log
